import os
from flask import Flask, request, jsonify
from flask_cors import CORS
from supabase import create_client, Client

app = Flask(__name__)
# تفعيل الـ CORS للسماح لـ Vercel بالاتصال بالسيرفر بدون حظر
CORS(app, resources={r"/*": {"origins": "*"}})

# إعدادات قاعدة بيانات Supabase (ستحصل عليها مجاناً عند التسجيل في supabase.com)
SUPABASE_URL = os.environ.get("SUPABASE_URL", "https://your-project.supabase.co")
SUPABASE_KEY = os.environ.get("SUPABASE_KEY", "your-anon-key")
supabase: Client = create_client(SUPABASE_URL, SUPABASE_KEY)

@app.route('/', methods=['GET'])
def home():
    return "سيرفر YAM يعمل ويرتبط بقاعدة البيانات بنجاح! 🚀", 200

@app.route('/save_attendance', methods=['POST'])
def save_attendance():
    try:
        data = request.get_json()
        if not data:
            return jsonify({"status": "error", "message": "لم يتم استقبال بيانات"}), 400

        # تجهيز البيانات لتخزينها في جدول اسمه attendance
        row_data = {
            "employee_name": data.get('employee'),
            "operation_type": data.get('type'),
            "target_location": data.get('target_location'),
            "actual_location": data.get('actual_location'),
            "date": data.get('date'),
            "time": data.get('time'),
            "total_hours": data.get('hours', 'غير محدد بعد')
        }

        # إدخال السطر في Supabase
        response = supabase.table("attendance").insert(row_data).execute()

        return jsonify({"status": "success", "message": "تم الحفظ في قاعدة البيانات بنجاح"}), 200

    except Exception as e:
        print(f"❌ خطأ: {str(e)}")
        return jsonify({"status": "error", "message": str(e)}), 500

if __name__ == '__main__':
    port = int(os.environ.get("PORT", 5000))
    app.run(host='0.0.0.0', port=port)
